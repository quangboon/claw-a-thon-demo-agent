# LLM configuration (OpenAI-compatible — GreenNode MaaS). Copy to .env and fill in.
# IAM credentials (GREENNODE_CLIENT_ID/SECRET) live in .greennode.json, not here.
LLM_BACKEND=openai-compat
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
# Model id must use the endpoint's path form, e.g. qwen/qwen3-5-27b (NOT the short code).
LLM_MODEL=qwen/qwen3-5-27b
