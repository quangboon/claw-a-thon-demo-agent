.greennode.json
.agentbase/
.env

# Python
.venv/
__pycache__/
*.pyc

# Runtime state (transient; corrections sync to AgentBase Memory in prod)
backend/review_queue.jsonl
backend/corrections.jsonl
backend/data/_test_*
# Per-profile runtime state (generated at runtime; seed profiles ship without it)
profiles/*/review_queue.jsonl
profiles/*/corrections.jsonl

# Frontend
web/node_modules/
web/dist/
# UI build artifact (rebuilt in Docker multi-stage)
backend/static/

plans/
.claude/
